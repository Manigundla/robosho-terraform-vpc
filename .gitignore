# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# Variable files with secrets
*.tfvars
*.tfvars.json

# OS / editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info